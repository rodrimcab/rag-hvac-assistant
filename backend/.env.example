APP_NAME="RAG HVAC Assistant API"
DEBUG=false
# Comma-separated origins for the Vite dev server (and production URLs when applicable)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google API key — get yours at https://aistudio.google.com/apikey
# Free tier works for development. Tier 1 (billing enabled) recommended for demos/defense.
GOOGLE_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────────────
# Gemini 1.5 Pro retired from consumer API (404 on new projects post-2025-Q1).
# Gemini 2.5 Pro requires paid tier (Free quota = 0 on new projects).
# Default: most capable model available on Free tier.
# GEMINI_LLM_MODEL=models/gemini-2.5-flash
# GEMINI_LLM_TEMPERATURE=0.1

# ── Embeddings ───────────────────────────────────────────────────────────────
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Tier 1: use Gemini embeddings maximum throughput (100 texts per request).
# EMBEDDING_BATCH_SIZE=100

# ── Chunking (winning config for HVAC service manuals) ───────────────────────
# MANUALS_DIR=data/manuals
# RAG_CHUNK_SIZE=1024
# RAG_CHUNK_OVERLAP=200
# RAG_MIN_NODE_TEXT_CHARS=12

# ── Retrieval ─────────────────────────────────────────────────────────────────
# top_k is set dynamically per query intent (diagnosis vs error_code).
# RAG_DIAGNOSIS_TOP_K=5        # complex queries → tree_summarize
# RAG_ERROR_CODE_TOP_K=3       # code lookups   → compact
# Omit document «sources» in JSON unless the question looks like a manual/HVAC query
# and each chunk clears these similarity gates (LlamaIndex: exp(-Chroma distance)).
# RAG_SOURCE_SCORE_FLOOR=0.515
# RAG_SOURCE_SCORE_MARGIN_FROM_TOP=0.035

# ── ChromaDB persistence ──────────────────────────────────────────────────────
# CHROMA_DB_PATH=./chroma_db
# CHROMA_COLLECTION_NAME=hvac_manuals

# ── Diagram vision (ingestion only; re-upload or re-index PDFs to apply) ─────
# DIAGRAM_VISION_ENABLED=true
# GEMINI_VISION_MODEL=gemini-2.5-flash
# DIAGRAM_VISION_MAX_PAGES_PER_PDF=10
# DIAGRAM_SKIP_VISION_MIN_TEXT_CHARS=2600
# DIAGRAM_VISION_MIN_DRAWINGS=150
