APP_NAME="RAG HVAC Assistant API"
DEBUG=false
# Comma-separated origins for the Vite dev server (and production URLs when applicable)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Phase 2+ RAG (Gemini via Google GenAI SDK; LlamaIndex reads GOOGLE_API_KEY if unset here)
